{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Termixion",
  "version": "0.0.1",
  "identifier": "dev.termixion.terminal",
  "build": {
    "frontendDist": "../../app/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter app build",
    "beforeDevCommand": "pnpm --filter app dev"
  },
  "app": {
    "windows": [
      {
        "title": "Termixion",
        "width": 900,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
