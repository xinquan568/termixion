{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Termixion",
  "version": "0.1.0",
  "identifier": "dev.termixion.terminal",
  "build": {
    "frontendDist": "../../app/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter app build",
    "beforeDevCommand": "pnpm --filter app dev"
  },
  "app": {
    "windows": [
      {
        "title": "Termixion",
        "width": 900,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/starship"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/xinquan568/termixion/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyRDY0RDg2NzNGMTAwQkMKUldTOEFQRnpoazNXRW5sQm1CdEdCbFU2c3V1dTgvMlBEbzZUd3hwY2M1c0V1Rmx3cEE5OFZVSUsK"
    }
  }
}
